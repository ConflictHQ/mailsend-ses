{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MailsendReadDeliverability",
      "Effect": "Allow",
      "Action": [
        "ses:GetAccount",
        "ses:ListEmailIdentities",
        "ses:GetEmailIdentity",
        "ses:GetSuppressedDestination",
        "ses:ListSuppressedDestinations"
      ],
      "Resource": "*"
    },
    {
      "Sid": "MailsendSend",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail"
      ],
      "Resource": "*"
    },
    {
      "Sid": "MailsendSuppressionManagement",
      "Effect": "Allow",
      "Action": [
        "ses:PutSuppressedDestination",
        "ses:DeleteSuppressedDestination"
      ],
      "Resource": "*"
    }
  ]
}
